# Mojaz Production Environment Variables Template
# Copy this file to .env.production and fill in the real secrets

# Database
DB_PASSWORD=MojazStrongPassword2025!

# Authentication
JWT_KEY=YourSuperSecretLongKeyAtLeast128BitsLongForSecurity
JWT_ISSUER=mojaz.gov.sa
JWT_AUDIENCE=mojaz-clients

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=mojaz-prod
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Persistence
LOG_PATH=./logs
UPLOADS_PATH=./uploads
DB_DATA_PATH=./db-data
