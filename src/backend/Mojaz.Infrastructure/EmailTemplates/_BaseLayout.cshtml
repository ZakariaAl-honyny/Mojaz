@* Bilingual Mojaz Email Base Layout *@
@model dynamic
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=600, initial-scale=1.0">
    <title>@(ViewBag.Title ?? "Mojaz Email")</title>
    <style>
        body { margin:0; padding:0; background:#f7f7f7; font-family:Tahoma, Arial, sans-serif; }
        .container { width:600px; margin:0 auto; background:#fff; border-radius:8px; overflow:hidden; }
        .header { background:#006C35; color:#fff; padding:24px 0; text-align:center; font-size:28px; font-weight:bold; letter-spacing:2px; }
        .row { display:flex; flex-direction:row; }
        .block-ar { direction:rtl; width:50%; padding:24px; border-left:1px solid #eee; background:#fafafa; }
        .block-en { direction:ltr; width:50%; padding:24px; }
        .footer { background:#f0f0f0; color:#888; text-align:center; font-size:12px; padding:16px 0; }
        @media (max-width: 600px) {
            .container { width:100% !important; }
            .row { flex-direction:column; }
            .block-ar, .block-en { width:100%; border:none; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">Mojaz | ăæ̀̉</div>
        <div class="row">
            <div class="block-ar">
                @RenderSection("Ar", required: false)
            </div>
            <div class="block-en">
                @RenderSection("En", required: false)
            </div>
        </div>
        <div class="footer">&copy; @(DateTime.UtcNow.Year) Mojaz. All rights reserved.</div>
    </div>
</body>
</html>
