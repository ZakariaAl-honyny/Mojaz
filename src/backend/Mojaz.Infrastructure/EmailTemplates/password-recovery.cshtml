@using Mojaz.Application.DTOs.Email.Templates
@model PasswordRecoveryEmailData
@{
    Layout = "_BaseLayout.cshtml";
}

@section Ar {
    <h2 style="color: #006C35; font-family: 'Cairo', sans-serif;">استعادة كلمة المرور</h2>
    <p>لقد تلقينا طلباً لإعادة تعيين كلمة المرور الخاصة بك. يرجى استخدام رمز التحقق التالي للمتابعة:</p>
    <div style="font-size: 32px; font-weight: bold; background: #f0fdf4; padding: 20px; text-align: center; border: 2px dashed #006C35; border-radius: 12px; color: #006C35; margin: 20px 0; letter-spacing: 5px;">
        @Model.OtpCode
    </div>
    <p style="color: #666; font-size: 14px;">تنتهي صلاحية هذا الرمز في: <strong>@Model.ExpiryTime</strong></p>
    <div style="background: #fee2e2; border-right: 4px solid #ef4444; padding: 15px; margin-top: 25px; border-radius: 8px;">
        <p style="color: #991b1b; font-weight: bold; margin: 0;">تنبيه أمني:</p>
        <p style="color: #991b1b; margin: 5px 0 0 0;">إذا لم تطلب إعادة تعيين كلمة المرور، يرجى تجاهل هذا البريد الإلكتروني واتخاذ الإجراءات اللازمة لحماية حسابك.</p>
    </div>
}

@section En {
    <h2 style="color: #006C35;">Password Recovery</h2>
    <p>We received a request to reset your password. Please use the following verification code to proceed:</p>
    <div style="font-size: 32px; font-weight: bold; background: #f0fdf4; padding: 20px; text-align: center; border: 2px dashed #006C35; border-radius: 12px; color: #006C35; margin: 20px 0; letter-spacing: 5px;">
        @Model.OtpCode
    </div>
    <p style="color: #666; font-size: 14px;">This code will expire at: <strong>@Model.ExpiryTime</strong></p>
    <div style="background: #fee2e2; border-left: 4px solid #ef4444; padding: 15px; margin-top: 25px; border-radius: 8px;">
        <p style="color: #991b1b; font-weight: bold; margin: 0;">Security Warning:</p>
        <p style="color: #991b1b; margin: 5px 0 0 0;">If you did not request a password reset, please ignore this email and take the necessary steps to secure your account.</p>
    </div>
}
