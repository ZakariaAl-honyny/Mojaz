@using Mojaz.Application.DTOs.Email.Templates
@model AccountVerificationEmailData
@{
    Layout = "_BaseLayout.cshtml";
}

@section Ar {
    <h2 style="color: #006C35; font-family: 'Cairo', sans-serif;">مرحباً بالعضو الجديد</h2>
    <p>شكراً لتسجيلك في منصة <strong>موجز</strong>. لتفعيل حسابك، يرجى استخدام رمز التحقق التالي:</p>
    <div style="font-size: 32px; font-weight: bold; background: #f0fdf4; padding: 20px; text-align: center; border: 2px dashed #006C35; border-radius: 12px; color: #006C35; margin: 20px 0; letter-spacing: 5px;">
        @Model.OtpCode
    </div>
    <p style="color: #666; font-size: 14px;">تنتهي صلاحية هذا الرمز في: <strong>@Model.ExpiryTime</strong></p>
    <p>إذا لم تكن قد طلبت هذا الرمز، فيرجى تجاهل هذا البريد الإلكتروني.</p>
}

@section En {
    <h2 style="color: #006C35;">Welcome to Mojaz!</h2>
    <p>Thank you for registering on the <strong>Mojaz</strong> platform. To activate your account, please use the following verification code:</p>
    <div style="font-size: 32px; font-weight: bold; background: #f0fdf4; padding: 20px; text-align: center; border: 2px dashed #006C35; border-radius: 12px; color: #006C35; margin: 20px 0; letter-spacing: 5px;">
        @Model.OtpCode
    </div>
    <p style="color: #666; font-size: 14px;">This code will expire at: <strong>@Model.ExpiryTime</strong></p>
    <p>If you did not request this code, please ignore this email.</p>
}
