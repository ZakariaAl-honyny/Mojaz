{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github",
        "${GITHUB_TOKEN}"
      ]
    },
    "play wright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "sql-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@mcp-collection/mssql-mcp",
        "Server=localhost,1434;Database=MojazDB;User Id=sa;Password=as123456;TrustServerCertificate=true"
      ]
    }
  }
}